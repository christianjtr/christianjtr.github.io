---
import '@fontsource/lato/index.css';
import { getEntry } from 'astro:content';

import { contentDataEntries, CONTENT } from '@app-types/Content';
import type { ContentDataEntryType } from '@app-types/Content';
import type { AboutMeData } from '@schemas/AboutMeSchema';
import { Header, Footer, MainWrapper } from '@layouts';
import { VerticalIconMenu, LocaleBanner } from '@components';
import { OpenGraph } from '@components/sections';
import '@styles/global.css';

export function getStaticPaths() {
    const pages = contentDataEntries.map((locale) => ({
        params: { lang: locale }
    }));

    return pages;
}

const { lang } = Astro.params;
const pageTitle = "Christian José Torrealba Rondón";
const rootTheme = { theme: 'light' };

const entry = await getEntry(lang as ContentDataEntryType, `${lang}/${CONTENT.COMMON}`);
const { header } = (entry?.data as AboutMeData) || {};
---

<html lang={lang} data-theme="light" {...rootTheme}>
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.ico" />
        <meta name="viewport" content="width=device-width" />
        <meta name="generator" content={Astro.generator} />
        <OpenGraph />
        <title>{pageTitle}</title>
    </head>
    <body>
        <a href="#main-content" class="skip-link sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-primary focus:text-white focus:rounded">Skip to main content</a>
        <Header transition:persist />
        <LocaleBanner
            currentLocale={lang!}
            languages={header.languages}
            bannerText={header.locale_banner}
        />
        <main id="main-content">
            <MainWrapper transition:animate="fade" />
        </main>
        <div class="vertical-icon-menu-wrapper hidden lg:flex" transition:persist>
            <VerticalIconMenu />
        </div>
        <button 
            id="scroll-top-button" 
            class="scroll-top-button" 
            aria-label="Scroll to top button"
            transition:name="scroll-top"
        >
            ☝🏼
        </button>
        <Footer transition:persist />

    </body>
</html>

<style>
    @reference "@styles/global.css";
    
    html {
        scroll-behavior: smooth;
    }
    
    .vertical-icon-menu-wrapper {
        @apply fixed top-1/3 right-5 z-1;
    }

    .scroll-top-button {
        @apply btn btn-xl btn-circle text-4xl border-0 hidden fixed justify-center items-center w-16 h-16 bottom-16 right-5 z-10 rounded-full;
        opacity: 0.8;
        background: var(--color-vibrant-pink);
    }

    .scroll-top-button:hover {
        filter: contrast(150%);
    }

    .scroll-top-button:focus {
        @apply outline-none;
    }
</style>

<script>
    window.onscroll = function() { scroll(); };
      
    const scrollDownUntil = 2500;
      
    const scrollToTopButton = document.getElementById("scroll-top-button");
    scrollToTopButton?.addEventListener("click", () => {
        goTotop();
    });
      
    function removeAnchors() {
        window.history.replaceState({}, "", window.location.href.split("#")[0]);
    }

    function scroll() {
        const validation = document.body.scrollTop > scrollDownUntil || document.documentElement.scrollTop > scrollDownUntil;
        scrollToTopButton!.style.display = validation ? "flex" : "none";
    }

    function goTotop() {
        document.body.scrollTop = 0;
        document.documentElement.scrollTop = 0;
        removeAnchors();
    }
</script>
 