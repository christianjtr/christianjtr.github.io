---
import { ClientRouter } from 'astro:transitions';
import { i18nLocalesConfig } from '../../i18n.config.mjs';

const { locales, defaultLocale } = i18nLocalesConfig;
const LOCALE_STORAGE_KEY = 'user-locale-preference';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <ClientRouter />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Redirecting...</title>
    <meta http-equiv="refresh" content="0;url=/en/" />
    <style>
      body {
        font-family: system-ui, -apple-system, sans-serif;
        margin: 2rem;
        line-height: 1.6;
        color: #333;
      }
      nav ul {
        list-style: none;
        padding: 0;
      }
      nav li {
        margin: 0.5rem 0;
      }
      nav a {
        text-decoration: none;
        color: #007acc;
        padding: 0.5rem;
        border-radius: 4px;
        transition: background-color 0.2s;
      }
      nav a:hover {
        background-color: #f0f8ff;
      }
    </style>
  </head>
  <body>
    <script is:inline define:vars={{ locales, defaultLocale, LOCALE_STORAGE_KEY }}>
      (() => {
        const getStoredLocale = () => {
          try {
            const stored = localStorage.getItem(LOCALE_STORAGE_KEY);
            return stored && locales.includes(stored) ? stored : null;
          } catch {
            return null;
          }
        };

        const storedLocale = getStoredLocale();
        if (storedLocale) {
          window.location.replace(`/${storedLocale}/`);
          return;
        }
        
        const browserLangs = navigator.languages?.length
          ? [...navigator.languages]
          : [navigator.language || 'en'];

        const targetLocale = browserLangs
          .map(lang => lang?.split(/[-_]/)?.[0]?.toLowerCase())
          .find(baseCode => baseCode && locales.includes(baseCode))
          ?? defaultLocale;

          try {
          localStorage.setItem(LOCALE_STORAGE_KEY, targetLocale);
        } catch {
        }
        window.location.replace(`/${targetLocale}/`);
      })();
    </script>
    <noscript>
      <p>JavaScript is required to detect your preferred language. Please choose:</p>
      <nav aria-label="Language selection">
        <ul>
          <li><a href="/en/">English</a></li>
          <li><a href="/es/">Español</a></li>
          <li><a href="/fr/">Français</a></li>
        </ul>
      </nav>
    </noscript>
  </body>
</html>
