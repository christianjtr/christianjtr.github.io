---
import { getEntry } from 'astro:content';

import type { ContentDataEntryType } from '@app-types/Content';
import type { Credentials } from '@schemas/CredentialSchema';
import type { AboutMeData } from '@schemas/AboutMeSchema';
import { CONTENT } from '@app-types/Content';
import Logo from '@assets/svg/certification.svg';
import { Section, LinkButton, VerticalSpacer } from "../";

const { lang } = Astro.params;

const [common, credentials] = await Promise.all([
    await getEntry(lang as ContentDataEntryType, `${lang}/${CONTENT.COMMON}`),
    await getEntry(lang as ContentDataEntryType, `${lang}/${CONTENT.CREDENTIALS}`)
]);

const { section_credentials, header } = (common?.data as AboutMeData) || {};
const { credly_credentials, certifications } = (credentials?.data as Credentials) || {};

const certificateCompaniesMap: Record<string, string> = {
    "Massachusetts Institute of Technology (MIT)": "https://upload.wikimedia.org/wikipedia/commons/5/5d/MIT_logo_2003-2023.svg",
    "Management 3.0 Foundation": "https://management30.com/wp-content/uploads/2019/01/Management30_Logo_Colour_SCREEN_72dpi-300x250.png",
    "IBM": "https://upload.wikimedia.org/wikipedia/commons/5/51/IBM_logo.svg",
    "HackerRank": "https://upload.wikimedia.org/wikipedia/commons/4/40/HackerRank_Icon-1000px.png"
};

---

<div class="bg-base-100 py-10" id={header.main_sections[1].anchorId}>
    <br />
    <Section headingTitle={section_credentials.title} subtitle={section_credentials.subtitle} class="container mx-auto px-1 lg:px-10">
        <Logo slot="beforeHeading" width={96} height={96} />
        <VerticalSpacer />
        <div class="flex lg:flex-row flex-col gap-8 px-1 lg:px-10">
            <div class="credential-list-wrapper">
                {credly_credentials.map(item => (
                    <a href={item.badge_url} target="_blank" rel="noopener noreferrer" class="credential-item">
                        <img src={item.image_url} width="110" height="110" class="mb-3" alt={item.name} aria-label={item.name} />
                        <span class="text-lg px-8 text-center">{item.name}</span>
                    </a>
                ))}
            </div>
            <div class="lg:w-2/5 w-full flex flex-col">
                <ul class="list">
                    {certifications.filter(({ display }) => display).map(item => (
                        <li class="list-row py-5 hover:bg-primary/5">
                            <div class="">
                                <img class="size-12 rounded-2xl bg-neutral-100 p-2 object-contain" src={certificateCompaniesMap[item.organization]} alt={`${item.organization} logo`} aria-label={`${item.organization} logo`} />
                            </div>
                            <p class="list-col-grow space-y-2">
                                <span class="text-xs text-info-content-color block">{item.organization}</span>
                                <span class="font-medium text-lg block">{item.title}</span>
                            </p>
                            <LinkButton href={item.url} target="_blank" rel="noopener noreferrer" class="btn-circle" displayDefaultIcon />
                        </li>
                    ))}
                </ul>
            </div>
        </div>
    </Section>
</div>

<style>
    @reference "@styles/global.css";

    .credential-list-wrapper {
        @apply grid md:grid-cols-2 gap-6 p-2 lg:w-3/5 w-full;
    }

    .credential-list-wrapper > .credential-item {
        @apply rounded-lg p-3 border cursor-pointer border-neutral-200 flex flex-col items-center transition-all duration-300 justify-center;
    }

    .credential-list-wrapper > .credential-item p {
        @apply flex flex-col items-center text-center;
    }
    
    .credential-list-wrapper > .credential-item:hover {
        @apply border border-primary/70 shadow-lg shadow-primary/10 -translate-y-1;
    }

    .text-info-content-color {
        @apply text-neutral-400;
    }

    html[data-theme="dark"] .text-info-content-color {
        @apply text-neutral-400;
    }

    html[data-theme="dark"] .credential-list-wrapper > .credential-item {
        @apply bg-neutral-900 border-neutral-800;
    }

    html[data-theme="dark"] .credential-list-wrapper > .credential-item:hover {
        @apply border-accent/70 shadow-accent/5;
    }

    html[data-theme="dark"] .list-row img {
        @apply bg-neutral-950;
    }
</style>