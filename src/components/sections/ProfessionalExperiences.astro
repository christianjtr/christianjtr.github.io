---
import { getCollection, getEntry } from "astro:content";
import type { ContentDataEntryType } from "@app-types/Content";
import type { Experience } from "@schemas/ExperienceSchema";
import type { Study } from "@schemas/StudySchema";
import type { AboutMeData } from "@schemas/AboutMeSchema";
import { CONTENT } from "@app-types/Content";
import { Section, AsyncImage, BadgeList, VerticalSpacer } from "../";
import Logo from "@assets/svg/background.svg";
import BuildingIcon from "@assets/svg/building.svg";
import AcademicCapIcon from "@assets/svg/academic_cap.svg";

type BackgroundType = "work" | "study";

interface Background {
    start_year: number;
    end_year: number | null;
    period: string;
    title: string;
    organization: string;
    isOngoing: boolean;
    description: string;
    flag_asset: string;
    country: string;
    topics: string[];
    category: string;
    contributions: string[];
    type: BackgroundType;
    location: string;
}

const { lang } = Astro.params;

const [commonData, [experiencesData], [studiesData]] = await Promise.all([
    await getEntry(lang as ContentDataEntryType, `${lang}/${CONTENT.COMMON}`),
    await getCollection(
        lang as ContentDataEntryType,
        (collection) => collection.id === `${lang}/${CONTENT.EXPERIENCES}`
    ),
    await getCollection(
        lang as ContentDataEntryType,
        (collection) => collection.id === `${lang}/${CONTENT.STUDIES}`
    ),
]);

const { section_studies, section_experiences, common, header } =
    (commonData?.data as AboutMeData) || {};
const { data: experiences } = experiencesData as { data: Experience[] };
const { data: studies } = studiesData as { data: Study[] };

const uniqueCountries = Array.from(
    new Set(experiences.map((eachExperience: Experience) => eachExperience.country))
);

const backgroundItems: Background[] = [
    ...experiences.map((eachExperience: Experience) => ({
        start_year: eachExperience.start_year,
        end_year: eachExperience.end_year,
        period: eachExperience.period,
        title: eachExperience.position,
        organization: eachExperience.company,
        isOngoing: eachExperience.isOngoing,
        description: eachExperience.description,
        flag_asset: eachExperience.flag_asset,
        country: eachExperience.country,
        topics: eachExperience.technologies,
        category: eachExperience.sector,
        contributions: eachExperience.contributions,
        location: eachExperience.location,
        type: "work" as BackgroundType,
    })),
    ...studies.map((eachStudy: Study) => ({
        start_year: eachStudy.start_year,
        end_year: eachStudy.end_year,
        period: eachStudy.period,
        title: eachStudy.degree,
        organization: eachStudy.school,
        isOngoing: eachStudy.isOngoing,
        description: eachStudy.description,
        flag_asset: eachStudy.flag_asset,
        country: eachStudy.country,
        topics: eachStudy.topics,
        category: eachStudy.subject,
        contributions: [],
        location: eachStudy.location,
        type: "study" as BackgroundType,
    })),
].sort((a, b) => {
    const yearA = a.end_year ?? Infinity;
    const yearB = b.end_year ?? Infinity;
    return yearB - yearA;
});

---

<div class="bg-base-100 py-10" id={header.main_sections[3].anchorId}>
    <br />
    <Section
        headingTitle={section_experiences.title}
        subtitle={section_experiences.subtitle}
        class="container mx-auto px-1 lg:px-10"
    >
        <Logo slot="beforeHeading" width={96} height={96} />
        <br />
        <div class="px-2 md:px-14">
            <div class="apple-editorial-grid">
                <div class="editorial-card card-synergy">
                    <div class="card-body-wrapper">
                        <div class="card-meta-header">
                            <BuildingIcon width={14} height={14} class="stroke-2 shrink-0" />
                            <span class="card-meta-title">{section_experiences.companies_across_regions}</span>
                        </div>
                        <h3 class="editorial-heading">
                            {section_experiences.collaborated_with}
                        </h3>
                    </div>
                    <div class="chip-container">
                        <BadgeList items={section_experiences.full_countries} badgeClass="font-semibold badge-soft text-[11px]" />
                    </div>
                </div>
                <div class="editorial-card card-academy">
                    <div class="card-body-wrapper">
                        <div class="card-meta-header">
                            <AcademicCapIcon width={14} height={14} class="stroke-2 shrink-0" />
                            <span class="card-meta-title">{section_studies.title}</span>
                        </div>
                        <h3 class="editorial-heading">{section_experiences.academic_foundation}</h3>
                    </div>
                    <div class="academy-footer">
                        <span class="truncate pr-2">{section_studies.educational_level}</span>
                    </div>
                </div>
            </div>
            <div class="w-full">
                <div class="w-full flex flex-col sm:flex-row sm:items-center justify-between gap-3 px-6 py-3.5 my-5 font-sans items-start">
                    <h1 class="text-xl font-black uppercase tracking-wide leading-none">
                        {common.experiences}
                    </h1>
                    <div class="flex text-current flex-wrap items-center gap-4 text-xs sm:text-sm font-mono font-bold">
                        <span class="inline-flex items-center gap-1.5">
                            <span class="w-1.5 h-1.5 rounded-full bg-primary"></span>
                            {uniqueCountries.length} {common.countries}
                        </span>
                        <span class="inline-flex items-center gap-1.5">
                            <span class="w-1.5 h-1.5 rounded-full bg-secondary"></span>
                            {backgroundItems.filter(item => item.type === "study").length} {common.formal_studies_taken}
                        </span>
                    </div>

                </div>
                <div class="grid grid-cols-1 lg:grid-cols-12 gap-5 w-full items-start">
                    <div class="lg:col-span-8 flex flex-col gap-4 w-full">
                        {uniqueCountries.map((countryName: string) => {
                            const regionalWork = backgroundItems.filter(item => item.country === countryName && item.type === "work");
                            
                            if (regionalWork.length === 0) return null;

                            return (
                                <div class="editorial-card rounded-lg p-5 shadow-2xs w-full space-y-4">
                                    <div class="flex items-center justify-between pb-2.5 w-full">
                                        <div class="flex items-center gap-2">
                                            {regionalWork.slice(0, 1).map((matched) => (
                                                <AsyncImage imagePath={matched.flag_asset} title={countryName} class="w-4.5 h-auto rounded-xs" />
                                            ))}
                                            <h3 class="text-sm font-black uppercase font-sans tracking-wider">{countryName}</h3>
                                        </div>
                                    </div>
                                    <div class="flex flex-col gap-4 w-full">
                                         {regionalWork.map((item) => {
                                             const isCurrentJob = item.isOngoing;

                                             return isCurrentJob ? (
                                                <div class="card bg-primary/20 rounded-lg p-4 w-full space-y-3 transition-all duration-300">
                                                    <div class="flex items-start justify-between gap-4 w-full">
                                                        <div class="space-y-0.5">
                                                            <span class="font-extrabold text-md block text-primary">{item.organization}</span>
                                                            <span class="text-sm font-semibold block leading-tight">{item.title}</span>
                                                        </div>
                                                        <span class="badge badge-ghost badge-sm font-sans font-bold uppercase text-[10px] tracking-wider px-2 py-1 h-auto animate-pulse shrink-0 select-none">
                                                            {common.ongoing}
                                                        </span>
                                                    </div>
                                                    <div class="flex items-center justify-between text-xs font-sans tracking-wider pt-2 select-none w-full">
                                                        <span class="font-medium">{item.category}</span>
                                                        <span class="font-mono text-xs font-bold shrink-0">{item.period}</span>
                                                    </div>
                                                </div>
                                            ) : (
                                                <div class="flex flex-col gap-1 background-item pl-3 py-0.5 transition-colors duration-200 w-full relative">
                                                    <span class="font-extrabold">{item.organization}</span>
                                                    <span class="text-sm font-medium block leading-tight">{item.title}</span>
                                                    
                                                    <div class="flex items-center justify-between text-xs font-sans pt-0.5 w-full select-none">
                                                        <span class="text-neutral-400">{item.category}</span>
                                                        <span class="font-mono text-xs text-neutral-400 font-bold shrink-0">{item.period}</span>
                                                    </div>
                                                </div>
                                            );
                                        })}
                                    </div>
                                </div>
                            );
                        })}
                    </div>
                    <div class="lg:col-span-4 editorial-card rounded-lg p-5 shadow-2xs flex flex-col w-full space-y-4 lg:sticky lg:top-24 hover:border-secondary/40 transition-colors duration-200">
                        <div class="flex items-center justify-between pb-2.5 w-full">
                            <div class="flex items-center gap-2">
                                <AcademicCapIcon width={14} height={14} class="text-secondary stroke-2" />
                                <span class="card-meta-title text-neutral-400">{common.educational_level}</span>
                            </div>
                        </div>
                    <div class="flex flex-col gap-4 w-full">
                        {backgroundItems.filter(item => item.type === "study").map((item) => (
                            <div class="flex flex-col gap-0.5 background-item pl-3 py-2 transition-colors duration-200 w-full">
                                <div class="flex items-baseline justify-between gap-3 w-full">
                                    <span class="font-bold text-sm">{item.organization}</span>
                                    <span class="font-mono text-xs text-neutral-400 font-bold shrink-0">{item.end_year}</span>
                                </div>
                                <div class="text-xs text-neutral-400 font-medium w-4/5 whitespace-normal leading-normal">{item.title}</div>
                            </div>
                        ))}
                    </div>
                </div>
            </div>
        </div>
    </div>
    </Section>
    <VerticalSpacer />
</div>

<style>
    @reference "@styles/global.css";

    .apple-editorial-grid {
        @apply w-full grid grid-cols-1 md:grid-cols-12 gap-6 items-stretch mb-12 select-none font-sans;
    }

    .editorial-card {
        @apply border rounded-lg p-6 md:p-8 flex flex-col justify-between transition-all duration-300 min-h-[180px] w-full;
        background-color: var(--fallback-b1, hsl(var(--b1)));
        border-color: #e5e5e5;
    }

    .editorial-card:hover {
        @apply border border-primary/70 shadow-lg shadow-primary/10 -translate-y-1;
    }

    .background-item {
        @apply border-l-2 border-transparent;
    }

    .background-item:hover {
        @apply border-primary/75;
    }

    html[data-theme="dark"] .background-item:hover {
        @apply border-accent;
    }

    .card-synergy {
        @apply md:col-span-7;
    }
    .card-academy {
        @apply md:col-span-5;
    }
    .card-body-wrapper {
        @apply space-y-4 w-full;
    }

    /* Cabeceras y Etiquetas de Metadatos */
    .card-meta-header {
        @apply flex items-center gap-2 text-neutral-400;
    }
    .card-meta-title {
        @apply text-[10px] font-bold uppercase tracking-widest font-mono;
    }
    .editorial-heading {
        @apply text-lg md:text-xl font-semibold text-neutral-800 tracking-tight leading-snug whitespace-normal max-w-lg;
    }

    /* Contenedores de Tags e Inyecciones de Sinergia */
    .chip-container {
        @apply flex flex-wrap gap-2 mt-3 pt-5 border-t w-full;
        border-color: rgba(229, 229, 229, 0.5);
    }
    .editorial-chip {
        @apply text-[10px] font-mono font-semibold px-2.5 py-1 rounded-md bg-white border border-neutral-200/50 text-neutral-500;
    }

    /* Resaltados de Texto Enlazados al Tema */
    .highlight-primary {
        @apply font-extrabold text-primary font-mono;
    }
    .highlight-secondary {
        @apply font-extrabold text-accent tabular-nums;
    }

    /* Componentes del Pie de la Tarjeta Académica */
    .academy-footer {
        @apply pt-4 border-t flex items-center justify-between text-[10px] font-bold text-secondary uppercase tracking-wider w-full;
        border-color: rgba(229, 229, 229, 0.5);
    }
    .footer-divider {
        @apply text-neutral-300 select-none font-normal;
    }
    .footer-status {
        @apply text-neutral-400 font-mono text-[9px] font-normal lowercase shrink-0;
    }

    html[data-theme="dark"] .editorial-card, html[data-theme="dark"] .editorial-card  {
        @apply bg-neutral-900 border-neutral-800 text-white;
    }
    html[data-theme="dark"] .editorial-card:hover {
        @apply border-accent/70 shadow-accent/5;
    }
    html[data-theme="dark"] .card-meta-header {
        @apply text-neutral-500;
    }
    html[data-theme="dark"] .editorial-heading {
        @apply text-white;
    }
    html[data-theme="dark"] .chip-container,
    html[data-theme="dark"] .academy-footer {
        border-color: rgba(38, 38, 38, 0.5);
    }
    html[data-theme="dark"] .editorial-chip {
        @apply bg-neutral-900 border-neutral-800 text-neutral-400;
    }
    html[data-theme="dark"] .highlight-primary {
        @apply text-accent;
    }
    html[data-theme="dark"] .footer-divider {
        @apply text-neutral-700;
    }

    
</style>

