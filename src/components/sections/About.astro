---
import { getEntry } from 'astro:content';
import { Image } from 'astro:assets';

import type { ContentDataEntryType } from '@app-types/Content';
import type { AboutMeData } from '@schemas/AboutMeSchema';
import { CONTENT } from '@app-types/Content';
import { VerticalSpacer } from "../";
import ExpertiseFeatureGrid from './ExpertiseFeatureGrid.astro';
import WaveAnimation from "@assets/gifs/wave.gif";
import CrystalBallAnimation from "@assets/gifs/crystal_ball.gif";
import MeImg from "@assets/images/me.png";

const { lang } = Astro.params;

const entry = await getEntry(lang as ContentDataEntryType, `${lang}/${CONTENT.COMMON}`);
const { section_about } = (entry?.data as AboutMeData) || {};
---

<div class="container mx-auto px-5 mt-10 lg:px-10 xl:px-10">
    <div class="grid lg:grid-cols-6">
        <div class="col-span-3 space-y-4 m-3 lg:m-12 content-center">
            <p class="flex items-center gap-2 font-medium">
                <Image src={WaveAnimation} width="64" height="64" alt="Waving" aria-label="Waving"/>
                <span class="text-3xl font-semibold text-accent">{section_about.greeting}</span>
            </p>
            <h1 class="font-semibold text-5xl lg:text-6xl leading-16" set:html={section_about.my_name_template} />
            <p class="text-lg lg:text-xl leading-8 p-2 m-0">{section_about.summary}</p>
        </div>
        <div class="col-span-3 p-12 relative flex justify-center">
            <figure class="avatar-image w-5/6 md:w-full">
                <Image src={MeImg} alt="My image" aria-label="My image" class="md:w-full" />
            </figure>
            <div class="chat absolute top-64 left-[-30px] w-1/2 hidden lg:block">
                <div class="chat-bubble">
                    <div class="text-slider-mask">
                        <div class="text-slider">
                            {section_about.avatar_messages.map((message: string) => (
                                <p class="no-select">{message}</p>
                            ))}
                            <p>{section_about.avatar_messages[0]}</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="grid md:grid-cols-8 about-me-wrapper">
        <div class="col-span-full lg:col-span-2 w-full rounded-lg">
            <span class="block font-semibold text-xl my-3">{section_about.hobbies_title}</span>
            <span class="block text-2xl">{section_about.hobbies}</span>
            <span class="block text-xs my-3 text-info-content-color">{section_about.language_tip}</span>
        </div>
        <div class="col-span-full lg:col-span-6 flex items-center">
            <div class="stats stats-vertical md:stats-horizontal w-full">
                {section_about.languages.map((language) => (
                    <div class="stat space-y-1">
                        <div class="stat-figure text-4xl">{language.emoji}</div>
                        <div class="stat-value font-semibold text-xl">{language.name}</div>
                        <div class="stat-desc text-info-content-color mb-3">{language.proficiency}</div>
                        <progress class="progress progress-primary w-3/4 lg:w-40 h-3.5" value={language.value} max="100" />
                        
                    </div>
                ))}
            </div>
        </div>
    </div>
    <VerticalSpacer />
    <div class="grid lg:grid-cols-6 gap-8 mt-5">
        <h3 class="col-span-1 lg:col-span-2 text-3xl font-semibold">{section_about.expertise.title}</h3>
        <div class="col-span-5 lg:col-span-4">
            <div class="divider divider-end flex items-center">
                <p class="tooltip-wrapper lg:tooltip-top">
                    <span class="tooltip-content p-2 max-w-48">{section_about.v_shaped_explanation}</span>
                    <span class="primary-text uppercase font-semibold cursor-pointer">
                        {section_about.v_shaped_profile}
                    </span>
                </p>
                <Image src={CrystalBallAnimation} width="60" height="60" alt="Crystal ball" aria-label="Crystal ball"/>
            </div>
        </div>
    </div>
    <VerticalSpacer />
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 mx-auto px-5 items-stretch mt-10">
        <div class="lg:col-span-4 flex flex-col justify-center text-left lg:pr-6 space-y-6">
            <div class="flex items-center gap-2">
                <span class="w-2 h-2 rounded-full bg-primary dark:bg-accent animate-pulse"></span>
                <span class="text-xs font-mono font-bold tracking-widest uppercase text-neutral-600 dark:text-primary">
                    {section_about.systems_thinking_mindset}
                </span>
            </div>
            <div class="relative">
                <p class="manifesto-title">{section_about.about_me_title}</p>
                <p class="manifesto-body">{section_about.about_me}</p>
            </div>
        </div>
        <ExpertiseFeatureGrid subjects={section_about.expertise.subjects} />
    </div>
</div>

<VerticalSpacer />

<style is:global>
    @reference "@styles/global.css";
    .primary-text {
        @apply text-primary;
    }

    .tooltip-wrapper {
        @apply tooltip tooltip-primary;
    }
    
    .manifesto-title {
        @apply text-xl lg:text-2xl font-black tracking-tight leading-snug text-neutral-900;
    }

    .manifesto-body {
        @apply text-base leading-relaxed text-neutral-900 mt-4 border-l-2 border-neutral-200 pl-6 font-medium;
    }

    html[data-theme="dark"] .manifesto-title {
        @apply text-white;
    }

    html[data-theme="dark"] .manifesto-body {
        @apply text-base-content border-primary;
    }

    html[data-theme="dark"] .primary-text {
        @apply text-accent;
    }

    html[data-theme="dark"] .tooltip-wrapper {
        @apply tooltip-accent;
    }
    
    .about-me-wrapper {
        @apply gap-8 shadow rounded-lg px-5 py-4 border border-neutral-100;
    }

    html[data-theme="dark"] .about-me-wrapper {
        @apply bg-neutral-900 border-neutral-800 text-white;
    }

    .text-info-content-color {
        @apply text-neutral-500;
    }

    html[data-theme="dark"] .text-info-content-color {
        @apply text-base-content;
    }
    
    .avatar-image {
        border-radius: 50%;
        background: linear-gradient(135deg, var(--color-cobalt-blue) 0%, var(--color-electric-teal) 100%);
    }

    .text-slider-mask {
        @apply h-[1.3rem] overflow-hidden;
    }

    .text-slider {
        animation: slideText 16s infinite cubic-bezier(0.7, 0, 0.3, 1);
    }

    .text-slider p {
        line-height: 1.3em;
        user-select: none;
        -webkit-user-select: none;
    }

    html[data-theme="dark"] .chat-bubble {
        @apply bg-slate-600;
    }

    @keyframes slideText {
        0%, 25% { transform: translateY(0%); }
        30%, 45% { transform: translateY(-25%); }
        50%, 70% { transform: translateY(-50%); }
        75%, 94.99% { transform: translateY(-75%); }
        95%, 100% { transform: translateY(0%); }
    }
</style>