---
import { getEntry } from 'astro:content';
import { Image } from 'astro:assets';

import type { ContentDataEntryType } from '@app-types/Content';
import type { AboutMeData } from '@schemas/AboutMeSchema';
import { CONTENT } from '@app-types/Content';
import { VerticalSpacer } from "../";
import ExpertiseFeatureGrid from './ExpertiseFeatureGrid.astro';
import WaveAnimation from "@assets/gifs/wave.gif";
import CrystalBallAnimation from "@assets/gifs/crystal_ball.gif";
import MeENImg from "@assets/images/me.png";
import MeFRImg from "@assets/images/me-fr.png";
import MeESImg from "@assets/images/me-es.png";

const { lang } = Astro.params;

const avatarMap: Record<string, ImageMetadata> = {  
    en: MeENImg,
    fr: MeFRImg,
    es: MeESImg,
};

const activeAvatar = avatarMap[lang as string] || MeENImg;

const entry = await getEntry(lang as ContentDataEntryType, `${lang}/${CONTENT.COMMON}`);
const { section_about } = (entry?.data as AboutMeData) || {};
---

<div class="container mx-auto px-5 mt-10">
    <div class="grid lg:grid-cols-6 relative overflow-hidden w-full">
        <div class="absolute left-0 top-[20%] opacity-15 dark:opacity-5 select-none pointer-events-none z-0 hidden lg:block">
            <svg width="400" height="200" fill="none" xmlns="http://w3.org">
                <path d="M0 20h400M0 80h400M0 140h400M60 0v200M180 0v200M300 0v200" stroke="currentColor" stroke-width="1"/>
                <circle cx="180" cy="80" r="4" class="fill-accent animate-ping" />
                <circle cx="180" cy="80" r="3" class="fill-accent" />
            </svg>
        </div>
        <div class="col-span-3 space-y-4 m-3 lg:m-12 content-center z-10">
            <p class="flex items-center gap-2 font-medium">
                <Image src={WaveAnimation} width="84" height="84" alt="Waving" aria-label="Waving"/>
                <span class="text-3xl font-semibold text-accent">{section_about.greeting}</span>
            </p>
            <h1 class="font-semibold text-5xl lg:text-6xl leading-16" set:html={section_about.my_name_template} />
            <div class="w-2/3 h-px bg-linear-to-r from-accent via-base-content/20 to-transparent my-4 relative">
                <span class="absolute -top-1 left-1/3 w-2 h-2 rounded-full bg-accent animate-pulse"></span>
            </div>
            <p class="text-lg lg:text-xl leading-8 p-2 m-0">{section_about.summary}</p>
        </div>
        <div class="col-span-3 p-12 relative flex justify-center z-10">
            <div class="absolute top-4 right-4 z-30 flex flex-col items-end text-right group/hobbies">
                <div class="btn btn-sm font-mono uppercase tracking-wider bg-base-200/80 group-hover/hobbies:bg-primary/20 group-hover/hobbies:border-primary group-hover/hobbies:text-primary group-hover/hobbies:font-bold backdrop-blur-sm border text-sm border-neutral-300 text-base-content/70 px-3.5 py-5 rounded-full cursor-pointer select-none transition-all duration-200 flex items-center gap-2 shadow-md">
                    <span class="text-sm">🧩</span>
                    <span>{section_about.hobbies_title}</span>
                </div>
                <div class="flex flex-col items-end gap-1.5 w-full max-h-0 opacity-0 -translate-y-2 pointer-events-none overflow-hidden transition-all duration-300 ease-out pl-4 group-hover/hobbies:max-h-40 group-hover/hobbies:opacity-100 group-hover/hobbies:translate-y-0 group-hover/hobbies:pointer-events-auto group-hover/hobbies:mt-2.5">
                    {section_about.hobbies.map((hobby) => (
                        <span class="text-[11px] font-semibold px-2.5 py-1 backdrop-blur-sm border border-primary/20 rounded-lg shadow whitespace-nowrap hover:border-primary/40 transition-colors">
                            {hobby.emoji} {hobby.name}
                        </span>
                    ))}
                </div>
            </div>
            <figure class="avatar-image w-5/6 md:w-full" transition:name="avatar">
                <Image src={activeAvatar} alt="My image" aria-label="My image" class="md:w-full"  />
            </figure>
            <div class="chat chat-end absolute top-64 w-3/5 hidden lg:flex z-1 filter drop-shadow-xl left-0">
                <div class="chat-bubble p-4 rounded-2xl rounded-tr-none shadow-2xl min-w-[200px] relative before:left-auto before:-right-1.5 before:rotate-45">
                    <div class="text-slider-mask overflow-hidden">
                        <div class="text-slider font-sans text-sm font-medium leading-relaxed tracking-wide">
                            {section_about.avatar_messages.map((message: string) => (
                                <p class="no-select py-0.5">{message}</p>
                            ))}
                            <p class="py-0.5">{section_about.avatar_messages[0]}</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <VerticalSpacer />
    <div class="grid grid-cols-1 lg:grid-cols-6 gap-6 w-full max-w-7xl mx-auto px-5">
        <div class="col-span-1 lg:col-span-2 space-y-2">
            <div class="flex items-center gap-2">
                <span class="w-2 h-2 rounded-full bg-primary dark:bg-accent animate-pulse shrink-0"></span>
                <span class="text-sm font-mono font-bold tracking-widest uppercase text-primary">
                    {section_about.systems_thinking_mindset}
                </span>
            </div>
            <h3 class="text-2xl lg:text-3xl font-bold text-base-content tracking-tight">
                {section_about.expertise.title}
            </h3>
        </div>
        <div class="col-span-1 lg:col-span-4">
            <div class="divider divider-end flex items-center border-dashed">
                <Image 
                    src={CrystalBallAnimation} 
                    width="76"
                    height="76"
                    alt="Crystal ball interface asset" 
                    aria-label="Crystal ball animation"
                    class="object-contain"
                />
            </div>
        </div>
    </div>
    <VerticalSpacer />
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 mx-auto px-5 items-stretch mt-10 w-full">
        <div class="lg:col-span-4 flex flex-col justify-center text-left lg:pr-6 space-y-5">
            <div class="relative">
                <p class="manifesto-title">{section_about.about_me_title}</p>
                <br />
                <p class="manifesto-body">{section_about.about_me}</p>
            </div>
            <div class="pt-5 space-y-2.5">
                <div class="flex items-center gap-2 text-[10px] font-mono uppercase tracking-widest text-base-content/70 select-none mb-5">
                    <span class="w-1.5 h-1.5 rounded-full bg-accent animate-pulse shrink-0"></span>
                    <span>{section_about.language_tip}</span>
                </div>
                {section_about.languages.map((language) => (
                    <div class="flex items-center justify-between font-medium px-5">
                        <div class="flex items-center gap-2 min-w-0 text-sm">
                            <span class="select-none text-3xl">{language.emoji}</span>
                            <span class="font-bold text-base-content shrink-0">{language.name}</span>
                            <span class="text-base-content/25 dark:text-neutral-700 hidden sm:inline">—</span>
                            <span class="text-base-content/60 truncate">{language.proficiency}</span>
                        </div>
                        <div class="flex gap-0.5 h-2 items-center shrink-0" aria-label={`Progress: ${language.value}`}>
                            <div class="w-2 h-2 rounded-xs bg-primary"></div>
                            <div class={`w-2 h-2 rounded-xs ${language.value >= 60 ? 'bg-primary' : 'bg-base-300 dark:bg-neutral-800'}`}></div>
                            <div class={`w-2 h-2 rounded-xs 
                                ${language.value === 100 ? 'bg-primary' : 'bg-base-300 dark:bg-neutral-800'} 
                                ${language.value < 100 && language.value >= 60 ? 'animate-pulse bg-primary/40' : ''}`}
                            ></div>
                        </div>
                    </div>
                ))}
            </div>
        </div>
        <div class="lg:col-span-8">
            <ExpertiseFeatureGrid subjects={section_about.expertise.subjects} />
        </div>
    </div>
</div>

<VerticalSpacer />

<style is:global>
    @reference "@styles/global.css";
    .primary-text {
        @apply text-primary;
    }

    .tooltip-wrapper {
        @apply tooltip tooltip-primary;
    }
    
    .manifesto-title {
        @apply text-xl lg:text-2xl font-black tracking-tight leading-snug text-neutral-900;
    }

    .manifesto-body {
        @apply text-base leading-relaxed text-neutral-900 mt-4 border-l-2 border-neutral-200 pl-6 font-medium;
    }

    html[data-theme="dark"] .manifesto-title {
        @apply text-white;
    }

    html[data-theme="dark"] .manifesto-body {
        @apply text-base-content border-primary;
    }

    html[data-theme="dark"] .primary-text {
        @apply text-accent;
    }

    html[data-theme="dark"] .tooltip-wrapper {
        @apply tooltip-accent;
    }
    
    .about-me-wrapper {
        @apply gap-8 shadow rounded-lg px-5 py-4 border border-neutral-100;
    }

    html[data-theme="dark"] .about-me-wrapper {
        @apply bg-neutral-900 border-neutral-800 text-white;
    }

    .text-info-content-color {
        @apply text-neutral-500;
    }

    html[data-theme="dark"] .text-info-content-color {
        @apply text-base-content;
    }
    
.avatar-image {
    background: linear-gradient(
        135deg, 
        color-mix(in srgb, var(--color-cobalt-blue) 60%, transparent) 0%, 
        color-mix(in srgb, var(--color-electric-teal) 50%, transparent) 100%
    );
    
    border-radius: 50%;
    
    backdrop-blur: 16px;
    -webkit-backdrop-blur: 16px;
    
    border: 1px solid color-mix(in srgb, var(--color-electric-teal) 55%, transparent);
    
    box-shadow: 
        inset 0 4px 14px color-mix(in srgb, white 20%, transparent),
        0 16px 40px color-mix(in srgb, var(--color-cobalt-blue) 35%, transparent);
        
    outline: 1px solid color-mix(in srgb, var(--color-cobalt-blue) 55%, transparent);
    outline-offset: 4px;
    
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}
.avatar-image:hover {
    border-color: color-mix(in srgb, var(--color-electric-teal) 75%, transparent);
    box-shadow: 
        inset 0 4px 20px color-mix(in srgb, white 25%, transparent),
        0 20px 48px color-mix(in srgb, var(--color-cobalt-blue) 45%, transparent);
}



    .text-slider-mask {
        @apply h-[1.3rem] overflow-hidden;
    }

    .text-slider {
        animation: slideText 16s infinite cubic-bezier(0.7, 0, 0.3, 1);
    }

    .text-slider p {
        line-height: 1.3em;
        user-select: none;
        -webkit-user-select: none;
    }

    html[data-theme="dark"] .chat-bubble {
        @apply bg-slate-500;
    }

    @keyframes slideText {
        0%, 25% { transform: translateY(0%); }
        30%, 45% { transform: translateY(-25%); }
        50%, 70% { transform: translateY(-50%); }
        75%, 94.99% { transform: translateY(-75%); }
        95%, 100% { transform: translateY(0%); }
    }
</style>