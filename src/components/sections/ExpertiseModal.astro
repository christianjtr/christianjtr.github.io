---
interface ExpertiseSubject {
    name: string;
    tools: string[];
}

interface Props {
    subject: ExpertiseSubject;
    modalId: string;
}

const { subject, modalId } = Astro.props;
---

<dialog id={modalId} class="modal modal-middle px-5 md:px-0" onclick="event.stopPropagation()">
    <div class="modal-box expertise-modal-box">
        
        <div class="expertise-modal-header">
            <div>
                <span class="expertise-modal-label">Integrated Stack</span>
                <h3 class="expertise-modal-title">{subject.name}</h3>
            </div>
            <form method="dialog">
                <button class="btn btn-sm btn-circle btn-ghost text-neutral-400 dark:text-neutral-500 hover:bg-neutral-100 dark:hover:bg-neutral-800">✕</button>
            </form>
        </div>

        <div class="expertise-modal-chip-list">
            {subject.tools.map((tool, tIdx) => (
                <Fragment>
                    <div class="expertise-modal-chip">
                        {tool}
                    </div>
                    {tIdx < subject.tools.length - 1 && (
                        <span class="expertise-modal-chip-separator">→</span>
                    )}
                </Fragment>
            ))}
        </div>
    </div>
</dialog>

<style>
    @reference "@styles/global.css";

    .expertise-modal-box {
        @apply bg-base-100 border-neutral-200 text-neutral-900 border rounded-2xl p-6 max-w-md w-full transition-all duration-300 shadow-2xl;
    }

    .expertise-modal-header {
        @apply flex items-center justify-between pb-3 mb-5 border-b border-neutral-100;
    }

    .expertise-modal-label {
        @apply text-[10px] font-bold tracking-widest text-primary uppercase font-mono;
    }

    .expertise-modal-title {
        @apply text-xl font-bold text-neutral-900;
    }

    .expertise-modal-chip-list {
        @apply flex flex-wrap items-center gap-x-2 gap-y-3 text-sm font-semibold tracking-tight;
    }

    .expertise-modal-chip {
        @apply bg-neutral-100 border-neutral-200 text-neutral-700 px-3 py-1.5 rounded-xl border hover:border-primary/50 transition-colors duration-200 cursor-default select-none;
    }

    .expertise-modal-chip-separator {
        @apply text-neutral-300 font-normal select-none mx-0.5;
    }

    html[data-theme="dark"] {
        & .expertise-modal-box {
            @apply bg-neutral-900 border-neutral-800 text-white;
        }

        & .expertise-modal-header {
            @apply border-neutral-800;
        }

        & .expertise-modal-label {
            @apply text-accent;
        }

        & .expertise-modal-title {
            @apply text-white;
        }

        & .expertise-modal-chip {
            @apply bg-neutral-950 border-neutral-800 text-neutral-200 hover:border-accent/50;
        }

        & .expertise-modal-chip-separator {
            @apply text-neutral-700;
        }
    }
</style>
