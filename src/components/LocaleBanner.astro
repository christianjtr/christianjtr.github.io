---
interface LocaleBannerText {
    message: string;
    action: string;
}

interface Language {
    locale: string;
    name: string;
}

interface Props {
    currentLocale: string;
    languages: Language[];
    bannerText: LocaleBannerText;
}

const { currentLocale, languages, bannerText } = Astro.props;

const languageMap = Object.fromEntries(
    languages.map(({ locale, name }) => [locale, name])
);
---

<div
    id="locale-banner"
    class="locale-banner"
    role="alert"
    aria-live="polite"
    hidden
>
    <div class="locale-banner-content">
        <p class="locale-banner-message">
            <span>{bannerText?.message}</span>
            <strong id="locale-banner-lang-name"></strong>
        </p>
        <div class="locale-banner-actions">
            <a id="locale-banner-switch" class="btn btn-sm btn-primary" href="#">
                {bannerText?.action}
            </a>
            <button
                id="locale-banner-dismiss"
                class="btn btn-sm btn-ghost btn-circle"
                aria-label="Dismiss"
            >
                ✕
            </button>
        </div>
    </div>
</div>

<style>
    @reference "@styles/global.css";

    .locale-banner {
        @apply w-full bg-info/10 border-b border-info/20 overflow-hidden;
        transition: max-height 0.3s ease, opacity 0.3s ease, padding 0.3s ease;
        max-height: 0;
        opacity: 0;
        padding: 0;
    }

    .locale-banner[data-visible="true"] {
        @apply py-2;
        max-height: 80px;
        opacity: 1;
    }

    .locale-banner-content {
        @apply container mx-auto flex items-center justify-between px-4 gap-3;
    }

    .locale-banner-message {
        @apply text-sm;
    }

    .locale-banner-actions {
        @apply flex items-center gap-2;
    }

    html[data-theme="dark"] .locale-banner {
        @apply bg-info/5 border-info/10;
    }
</style>

<script is:inline define:vars={{ currentLocale, languageMap }}>
    (() => {
        const LOCALE_STORAGE_KEY = 'user-locale-preference';
        const BANNER_DISMISSED_KEY = 'locale-banner-dismissed';

        const banner = document.getElementById('locale-banner');
        const langNameEl = document.getElementById('locale-banner-lang-name');
        const switchBtn = document.getElementById('locale-banner-switch');
        const dismissBtn = document.getElementById('locale-banner-dismiss');

        if (!banner || !langNameEl || !switchBtn || !dismissBtn) return;

        const safeGet = (k) => {
            try { return localStorage.getItem(k); } catch { return null; }
        };
        const safeSet = (k, v) => {
            try { localStorage.setItem(k, v); } catch { /* ignore */ }
        };

        if (safeGet(LOCALE_STORAGE_KEY)) return;
        if (safeGet(BANNER_DISMISSED_KEY) === 'true') return;

        const browserLangs = (Array.isArray(navigator.languages) && navigator.languages.length)
            ? navigator.languages
            : [navigator.language || ''];

        let detectedLocale = null;
        for (const l of browserLangs) {
            if (!l) continue;
            const baseCode = l.split(/[-_]/)[0].toLowerCase();
            if (baseCode && languageMap?.[baseCode]) {
                detectedLocale = baseCode;
                break;
            }
        }

        if (!detectedLocale || detectedLocale === currentLocale) return;

        const suggestedName = languageMap[detectedLocale];
        langNameEl.textContent = ` ${suggestedName}`;
        switchBtn.setAttribute('href', `/${detectedLocale}/`);

        banner.removeAttribute('hidden');
        banner.offsetHeight;
        banner.setAttribute('data-visible', 'true');

        switchBtn.addEventListener('click', () => safeSet(LOCALE_STORAGE_KEY, detectedLocale));

        dismissBtn.addEventListener('click', () => {
            banner.setAttribute('data-visible', 'false');
            safeSet(BANNER_DISMISSED_KEY, 'true');
            setTimeout(() => banner.setAttribute('hidden', ''), 300);
        });
    })();
</script>
