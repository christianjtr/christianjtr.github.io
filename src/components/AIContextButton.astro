---
import llmsTextRaw from '/public/llms.txt?raw';

import { getEntry } from 'astro:content';
import { getProfilePrompt } from '@utils/profilePromptGenerator';
import type { ContentDataEntryType } from '@app-types/Content';
import { CONTENT } from '@app-types/Content';
import type { AboutMeData } from '@schemas/AboutMeSchema';

const { lang } = Astro.params;
const locale = (lang as string) || 'en';

let entry = null;
try {
  entry = await getEntry(locale as ContentDataEntryType, `${locale}/${CONTENT.COMMON}`);
} catch (e) {
  console.error(`Failed to fetch content for locale: ${locale}`, e);
}

const common = (entry?.data as AboutMeData)?.common ?? {};
const buttonText = common.ai_button_text ?? 'Feed to AI';
const copiedText = common.ai_copied_text ?? 'Ready to paste';
const promptInstruction = getProfilePrompt(llmsTextRaw, common.ai_instruction);
---

<button
  id="ai-context-button"
  type="button"
  class="inline-flex items-center justify-between p-3 rounded-2xl text-left border bg-base-200 border-base-300 text-base-content hover:bg-base-200 hover:border-base-300 cursor-pointer transition-all duration-200 min-w-56 h-auto group"
  data-lang={lang}
  data-copied-text={copiedText}
  aria-label={buttonText}
>
  <span class="flex flex-col items-start">
    <span class="text-[11px] font-bold uppercase tracking-[0.35em] text-primary group-hover:text-primary transition-colors duration-200">
      AI Summary
    </span>
    <span class="text-sm font-semibold" id="ai-button-text">
      {buttonText}
    </span>
  </span>

  <span class="relative flex items-center justify-center shrink-0 w-5 h-5" aria-hidden="true">
    <span class="ai-voice-bars absolute inset-0 flex items-center justify-center gap-1 transition-opacity duration-200"></span>
    <svg xmlns="http://w3.org" viewBox="0 0 24 24" class="ai-check-icon hidden absolute w-5 h-5 text-current">
      <path d="M5 13l4 4L19 7" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  </span>
</button>

<script is:inline define:vars={{ promptInstruction }}>
  const button = document.getElementById('ai-context-button');
  const labelSpan = document.getElementById('ai-button-text');
  
  if (button && labelSpan) {
    const copiedText = button.dataset.copiedText || 'Copied';
    const originalLabel = labelSpan.textContent || '';
    let timeoutId = null;

    button.addEventListener('click', async () => {
      if (!promptInstruction) return;
      
      try {
        await navigator.clipboard.writeText(promptInstruction);
      } catch (error) {
        const input = document.createElement("textarea");
        input.value = promptInstruction;
        input.style.position = "fixed";
        input.style.opacity = "0";
        document.body.appendChild(input);
        input.select();
        document.execCommand('copy');
        document.body.removeChild(input);
      }
      
      if (timeoutId) clearTimeout(timeoutId);
      
      button.classList.add('copied');
      button.setAttribute('aria-label', copiedText);
      labelSpan.textContent = copiedText;

      timeoutId = window.setTimeout(() => {
        button.classList.remove('copied');
        button.setAttribute('aria-label', originalLabel);
        labelSpan.textContent = originalLabel;
      }, 2200);
    });
  }
</script>

<style>
  @reference "@styles/global.css";
  .ai-voice-bars::before, .ai-voice-bars::after {
    content: '';
    display: inline-block;
    width: 3px;
    background-color: currentColor;
    border-radius: 9999px;
    animation: ai-wave 1s ease-in-out infinite;
  }
  
  .ai-voice-bars::before { 
    height: 10px; 
    animation-delay: 0.05s; 
  }
  
  .ai-voice-bars::after { 
    height: 15px; 
    animation-delay: 0.2s; 
  }

  button:hover {
    @apply border-primary;
  }
  
  html[data-theme="dark"] button {
    @apply text-white bg-slate-950;
  }
  
  html[data-theme="dark"] button:hover {
    @apply border-accent;
  }

  #ai-context-button.copied .ai-voice-bars { @apply opacity-0 pointer-events-none; }
  #ai-context-button.copied .ai-check-icon { @apply block; }
  
  @keyframes ai-wave {
    0%, 100% { transform: scaleY(0.6); opacity: 0.7; }
    50% { transform: scaleY(1.1); opacity: 1; }
  }
</style>
